# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
dist/
build/
.claude/


# ---------- 虚拟环境 ----------
.venv/
venv/
ENV/

# ---------- 敏感文件（绝对不能上传！）----------
