data/config.yaml
data/reply_hash_cache.json

# ---------- IDE / 编辑器 ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- 调试产物 ----------
debug_*.png
*.log

# ---------- PaddleOCR 模型缓存 ----------
~/.paddleocr/

# ---------- 系统杂项 ----------
*.bak
*.tmp
